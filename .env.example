# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env no repositório.

# IMPORTANTE: Os dois tokens abaixo devem ser IDÊNTICOS para o frontend
# conseguir se autenticar com o backend.
APPSEC_API_TOKEN=changeme-token
VITE_API_TOKEN=changeme-token

# Opcional: origens CORS permitidas (padrão: localhost)
APPSEC_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
