# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env no repositório.

# IMPORTANTE: Gere um token seguro e use o MESMO valor nos dois campos abaixo.
# O backend NÃO inicia se APPSEC_API_TOKEN estiver vazio.
# Exemplo: APPSEC_API_TOKEN=$(openssl rand -hex 32)
APPSEC_API_TOKEN=mude-para-um-token-seguro
VITE_API_TOKEN=mude-para-um-token-seguro

# Opcional: origens CORS permitidas (padrão: localhost)
APPSEC_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
